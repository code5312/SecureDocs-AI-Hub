APP_ENV=development
APP_NAME=SecureDocs AI Hub
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-development-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256
REFRESH_COOKIE_NAME=securedocs_refresh_token
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=securedocs
POSTGRES_USER=securedocs
POSTGRES_PASSWORD=securedocs_password
REDIS_URL=redis://redis:6379/0

CELERY_BROKER_URL=redis://redis:6379/1
EXTRACTION_MAX_FILE_SIZE_MB=50
EXTRACTION_MAX_PAGES=500
EXTRACTION_MAX_SLIDES=500
EXTRACTION_MAX_SHEETS=100
EXTRACTION_MAX_ROWS_PER_SHEET=100000
EXTRACTION_MAX_CHARACTERS=2000000
EXTRACTION_MAX_CHUNKS=5000
EXTRACTION_CHUNK_SIZE=1200
EXTRACTION_CHUNK_OVERLAP=200
EXTRACTION_MAX_ATTEMPTS=3
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=false
MINIO_DOCUMENT_BUCKET=documents-original
MINIO_PREVIEW_BUCKET=documents-preview
MINIO_BACKUP_BUCKET=documents-backup
MINIO_DATABASE_BACKUP_BUCKET=database-backup
MINIO_CONNECT_TIMEOUT_SECONDS=2.0
MINIO_READ_TIMEOUT_SECONDS=2.0
DOCUMENT_MAX_UPLOAD_SIZE_MB=50
DOCUMENT_ALLOWED_EXTENSIONS=pdf,docx,pptx,xlsx,txt,md
DOCUMENT_DOWNLOAD_URL_EXPIRES_SECONDS=300
CORS_ORIGINS=http://localhost,http://localhost:3000,http://frontend:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost/api/v1
API_INTERNAL_BASE_URL=http://backend:8000/api/v1
